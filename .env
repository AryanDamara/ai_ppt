# OpenAI — use pinned model versions
OPENAI_API_KEY=sk-...

# Database
DATABASE_URL=postgresql+asyncpg://aippt:aipptdev@localhost:5432/aippt
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Redis
REDIS_URL=redis://localhost:6379/0

# App settings
ENVIRONMENT=development
LOG_LEVEL=INFO
PIPELINE_VERSION=1.0.0
SCHEMA_VERSION=1.0.0

# Rate limiting
RATE_LIMIT_PER_MINUTE=10

# OpenAI config
OPENAI_MODEL_PRIMARY=gpt-4o-2024-08-06
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_FALLBACK=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_SECONDS=30
OPENAI_EMBEDDING_DIMENSION=1536

# Cache
CACHE_SIMILARITY_THRESHOLD=0.92
CACHE_TTL_HOURS=24

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── Phase 4: RAG Pipeline (Ingestion Service) ────────────────────────────────
# Pinecone vector database
PINECONE_API_KEY=pc-...
PINECONE_INDEX_NAME=aippt-documents
PINECONE_ENVIRONMENT=us-east-1-aws

# AWS S3 (raw document storage)
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_RAW_DOCUMENTS_BUCKET=aippt-raw-documents
S3_EXPORT_BUCKET=aippt-exports

# ── Phase 5: LLMOps, Auth & Scale ────────────────────────────────────────
# LangSmith observability
LANGSMITH_API_KEY=ls-...
LANGSMITH_PROJECT=aippt-production
LANGSMITH_SAMPLE_RATE=0.10

# Supabase Auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Prompt registry
PROMPT_HOT_RELOAD=false

# Dynamic model routing
FORCE_MODEL=

# Cost monitoring
MAX_COST_PER_CALL_USD=5.0
DEFAULT_DAILY_BUDGET_USD=10.0

# Google Slides export (OAuth client for server-initiated exports)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
